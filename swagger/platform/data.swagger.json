        "data": {
          "type": "object",
          "description": "Decoded/processed payload as JSON."
        },
        "metadata": {
          "type": "object",
          "description": "Optional arbitrary metadata."
        },
        "dataTimestamp": {
          "type": "string",
          "format": "date-time",
