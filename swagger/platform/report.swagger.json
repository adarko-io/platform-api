{
  "swagger": "2.0",
  "info": {
    "title": "platform/report.proto",
    "version": "version not set"
  },
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/reports": {
      "get": {
        "summary": "List reports for the tenant.",
        "operationId": "ReportService_ListReports",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/platformListReportsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/runtimeError"
            }
          }
        },
        "parameters": [
          {
            "name": "tenantId",
            "in": "query",
            "required": false,
            "type": "string"
          },
          {
            "name": "reportType",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "REPORT_TYPE_UNSPECIFIED",
              "REPORT_TYPE_CONNECTION_TIME_GRID",
              "REPORT_TYPE_CONNECTION_GRID",
              "REPORT_TYPE_CONNECTION_AGGREGATED_GRID"
            ],
            "default": "REPORT_TYPE_UNSPECIFIED"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "REPORT_CATEGORY_UNSPECIFIED",
              "REPORT_CATEGORY_EXPORT",
              "REPORT_CATEGORY_IMPORT"
            ],
            "default": "REPORT_CATEGORY_UNSPECIFIED"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "REPORT_STATUS_UNSPECIFIED",
              "REPORT_STATUS_IN_PROGRESS",
              "REPORT_STATUS_COMPLETED",
              "REPORT_STATUS_FAILED"
            ],
            "default": "REPORT_STATUS_UNSPECIFIED"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int64"
          }
        ],
        "tags": [
          "ReportService"
        ]
      }
    },
    "/api/reports/{reportId}/download": {
      "get": {
        "summary": "Download a completed report file (server streaming).",
        "operationId": "ReportService_DownloadReport",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/platformDownloadReportResponse"
                },
                "error": {
                  "$ref": "#/definitions/runtimeStreamError"
                }
              },
              "title": "Stream result of platformDownloadReportResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/runtimeError"
            }
          }
        },
        "parameters": [
          {
            "name": "reportId",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "tenantId",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ReportService"
        ]
      }
    }
  },
  "definitions": {
    "platformDownloadMetadata": {
      "type": "object",
      "properties": {
        "filename": {
          "type": "string",
          "description": "File name."
        },
        "contentType": {
          "type": "string",
          "description": "MIME content type (e.g. \"text/csv\", \"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet\")."
        },
        "totalSize": {
          "type": "string",
          "format": "int64",
          "description": "Total file size in bytes."
        }
      },
      "description": "Metadata sent as the first message in a streaming file download response."
    },
    "platformDownloadReportResponse": {
      "type": "object",
      "properties": {
        "metadata": {
          "$ref": "#/definitions/platformDownloadMetadata"
        },
        "chunk": {
          "type": "string",
          "format": "byte"
        }
      },
      "description": "Response for downloading a report file (streaming). First message contains metadata,\nsubsequent messages contain file chunks."
    },
    "platformListReportsResponse": {
      "type": "object",
      "properties": {
        "totalCount": {
          "type": "integer",
          "format": "int64"
        },
        "reports": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/platformReport"
          }
        }
      }
    },
    "platformReport": {
      "type": "object",
      "properties": {
        "reportId": {
          "type": "string"
        },
        "tenantId": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "description": "File name (without path)."
        },
        "reportType": {
          "$ref": "#/definitions/platformReportType"
        },
        "category": {
          "$ref": "#/definitions/platformReportCategory"
        },
        "status": {
          "$ref": "#/definitions/platformReportStatus"
        },
        "tags": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Contextual metadata: e.g. {\"type\":\"consumption\",\"start_time\":\"...\",\"field\":\"...\"}"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "errorMessage": {
          "type": "string"
        }
      },
      "description": "A report job record."
    },
    "platformReportCategory": {
      "type": "string",
      "enum": [
        "REPORT_CATEGORY_UNSPECIFIED",
        "REPORT_CATEGORY_EXPORT",
        "REPORT_CATEGORY_IMPORT"
      ],
      "default": "REPORT_CATEGORY_UNSPECIFIED",
      "description": "Report category — direction of data flow."
    },
    "platformReportStatus": {
      "type": "string",
      "enum": [
        "REPORT_STATUS_UNSPECIFIED",
        "REPORT_STATUS_IN_PROGRESS",
        "REPORT_STATUS_COMPLETED",
        "REPORT_STATUS_FAILED"
      ],
      "default": "REPORT_STATUS_UNSPECIFIED",
      "description": "Report processing status."
    },
    "platformReportType": {
      "type": "string",
      "enum": [
        "REPORT_TYPE_UNSPECIFIED",
        "REPORT_TYPE_CONNECTION_TIME_GRID",
        "REPORT_TYPE_CONNECTION_GRID",
        "REPORT_TYPE_CONNECTION_AGGREGATED_GRID"
      ],
      "default": "REPORT_TYPE_UNSPECIFIED",
      "description": "Report type — what kind of data the report covers."
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "typeUrl": {
          "type": "string"
        },
        "value": {
          "type": "string",
          "format": "byte"
        }
      }
    },
    "runtimeError": {
      "type": "object",
      "properties": {
        "error": {
          "type": "string"
        },
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "runtimeStreamError": {
      "type": "object",
      "properties": {
        "grpcCode": {
          "type": "integer",
          "format": "int32"
        },
        "httpCode": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "httpStatus": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    }
  }
}
